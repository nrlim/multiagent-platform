# ─── Dependencies ───────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
.pnp/
.pnp.*

# ─── Python (Engine) ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
ENV/
env/
.pytest_cache/
.mypy_cache/
.tox/
.coverage
htmlcov/

# ─── Next.js / React (Dashboard) ───────────────────────────────────────────
.next/
out/
build/
dist/
.vercel
*.tsbuildinfo
next-env.d.ts
.turbo/

# ─── Environment / Secrets ─────────────────────────────────────────────────
# Ignore all env files by default for security
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# If you specifically want to track prod/example envs, you can uncomment these:
# !.env.prod
# !.env.example

# ─── Databases ─────────────────────────────────────────────────────────────
*.db
*.db-journal
*.sqlite
*.sqlite-journal

# ─── Workspace (Agent Output) ──────────────────────────────────────────────
# We usually want to ignore the recursive dependencies and builds inside agent workspaces
workspace/**/node_modules/
workspace/**/.next/
workspace/**/dist/
workspace/**/build/
workspace/**/.venv/

# ─── Prisma ────────────────────────────────────────────────────────────────
packages/database/prisma/*.db
packages/database/prisma/*.db-journal
packages/database/prisma/generated/

# ─── OS / IDE ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ─── Logs ──────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
