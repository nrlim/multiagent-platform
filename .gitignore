# ─── Dependencies ───────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
.pnp/
.pnp.*
.npm/
.eslintcache
.stylelintcache
*.tsbuildinfo

# ─── Python (Engine) ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
ENV/
env/
.pytest_cache/
.mypy_cache/
.tox/
.coverage
htmlcov/

# ─── Next.js / React (Dashboard) ───────────────────────────────────────────
.next/
out/
build/
dist/
.vercel
.turbo/
.cache/
.parcel-cache/
next-env.d.ts

# ─── Environment / Secrets ─────────────────────────────────────────────────
# Ignore all env files by default for security
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# If you specifically want to track prod/example envs, you can uncomment these:
# !.env.prod
# !.env.example

# ─── Workspace (Agent Output) ──────────────────────────────────────────────
# We usually want to ignore the recursive dependencies and builds inside agent workspaces
workspace/*
workspace/**/node_modules/
workspace/**/.next/
workspace/**/dist/
workspace/**/build/
workspace/**/.venv/
workspace/**/__pycache__/
workspace/**/*.py[cod]
workspace/**/.env*

# ─── Prisma / Database ─────────────────────────────────────────────────────
packages/database/prisma/*.db
packages/database/prisma/*.db-journal
packages/database/prisma/generated/
*.db
*.db-journal
*.sqlite
*.sqlite-journal

# ─── OS / IDE ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.history/

# ─── Logs / Misc ───────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
coverage/
junit.xml
*.patch
*.diff
